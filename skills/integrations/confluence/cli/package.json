{
  "name": "sdlc-confluence-cli",
  "version": "0.1.0",
  "description": "Read-only CLI tool for the agent to interact with Confluence Cloud REST API",
  "bin": {
    "confluence-cli": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["sdlc", "confluence", "documentation", "agent"],
  "author": "Skill Package Maintainers",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": ["dist"]
}
